// Tests for: Token
// Ported from: test/token.mjs (markdown-it v14.1.1)

open import "std/string";
{ Token, StringPair } :: import "../src/token.yo";

test "Token ŌĆö constructor defaults", {
  tok := Token.new(`paragraph_open`, `p`, i32(1));
  assert((tok.type_name == `paragraph_open`), "type_name should match");
  assert((tok.tag == `p`), "tag should match");
  assert((tok.nesting == i32(1)), "nesting should match");
  assert((tok.level == i32(0)), "level should default to 0");
  assert((tok.content == ``), "content should default to empty");
  assert((tok.markup == ``), "markup should default to empty");
  assert((tok.info == ``), "info should default to empty");
  assert((tok.block == false), "block should default to false");
  assert((tok.hidden == false), "hidden should default to false");
};

test "Token ŌĆö attrIndex with no attrs", {
  (tok : Token) = Token.new(`inline`, ``, i32(0));
  (idx : i32) = (&tok).attrIndex(`href`);
  assert((idx == i32(-1)), "should return -1 when no attrs");
};

test "Token ŌĆö attrPush", {
  (tok : Token) = Token.new(`link_open`, `a`, i32(1));
  (&tok).attrPush(StringPair(name: `href`, value: `https://example.com`));

  (idx : i32) = (&tok).attrIndex(`href`);
  assert((idx == i32(0)), "should find pushed attr at index 0");
};

test "Token ŌĆö attrSet creates new attr", {
  (tok : Token) = Token.new(`link_open`, `a`, i32(1));
  (&tok).attrSet(`href`, `https://example.com`);

  (val : Option(String)) = (&tok).attrGet(`href`);
  match(val,
    .Some(v) => assert((v == `https://example.com`), "should get correct value"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö attrSet overrides existing", {
  (tok : Token) = Token.new(`link_open`, `a`, i32(1));
  (&tok).attrSet(`href`, `old`);
  (&tok).attrSet(`href`, `new`);

  (val : Option(String)) = (&tok).attrGet(`href`);
  match(val,
    .Some(v) => assert((v == `new`), "should override with new value"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö attrGet returns None for missing attr", {
  (tok : Token) = Token.new(`inline`, ``, i32(0));
  (val : Option(String)) = (&tok).attrGet(`class`);
  match(val,
    .Some(_) => assert(false, "should not find attr"),
    .None => ()
  );
};

test "Token ŌĆö attrJoin creates new attr", {
  (tok : Token) = Token.new(`paragraph_open`, `p`, i32(1));
  (&tok).attrJoin(`class`, `foo`);

  (val : Option(String)) = (&tok).attrGet(`class`);
  match(val,
    .Some(v) => assert((v == `foo`), "should create attr with value"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö attrJoin appends to existing", {
  (tok : Token) = Token.new(`paragraph_open`, `p`, i32(1));
  (&tok).attrJoin(`class`, `foo`);
  (&tok).attrJoin(`class`, `bar`);

  (val : Option(String)) = (&tok).attrGet(`class`);
  match(val,
    .Some(v) => assert((v == `foo bar`), "should join with space"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö multiple different attrs", {
  (tok : Token) = Token.new(`link_open`, `a`, i32(1));
  (&tok).attrSet(`href`, `https://example.com`);
  (&tok).attrSet(`title`, `Example`);
  (&tok).attrJoin(`class`, `link`);

  assert(((&tok).attrIndex(`href`) == i32(0)), "href at index 0");
  assert(((&tok).attrIndex(`title`) == i32(1)), "title at index 1");
  assert(((&tok).attrIndex(`class`) == i32(2)), "class at index 2");
  assert(((&tok).attrIndex(`missing`) == i32(-1)), "missing returns -1");
};
