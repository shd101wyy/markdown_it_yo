// Tests for: Token
// Ported from: test/token.mjs (markdown-it v14.1.1)

open import "std/string";
{ Token, TokenType, StringPair } :: import "../src/token.yo";

test "Token ŌĆö constructor defaults", {
  tok := Token.new(.TT_PARAGRAPH_OPEN, "p", i32(1));
  assert((tok.type_name == .TT_PARAGRAPH_OPEN), "type_name should match");
  assert((tok.tag == "p"), "tag should match");
  assert((tok.nesting == i32(1)), "nesting should match");
  assert((tok.level == i32(0)), "level should default to 0");
  assert((tok.content == ``), "content should default to empty");
  assert((tok.markup == ``), "markup should default to empty");
  assert((tok.info == ``), "info should default to empty");
  assert((tok.block == false), "block should default to false");
  assert((tok.hidden == false), "hidden should default to false");
};

test "Token ŌĆö attr_index with no attrs", {
  (tok : Token) = Token.new(.TT_INLINE, "", i32(0));
  (idx : i32) = (&tok).attr_index(`href`);
  assert((idx == i32(-1)), "should return -1 when no attrs");
};

test "Token ŌĆö attr_push", {
  (tok : Token) = Token.new(.TT_LINK_OPEN, "a", i32(1));
  (&tok).attr_push(StringPair(name: `href`, value: `https://example.com`));

  (idx : i32) = (&tok).attr_index(`href`);
  assert((idx == i32(0)), "should find pushed attr at index 0");
};

test "Token ŌĆö attr_set creates new attr", {
  (tok : Token) = Token.new(.TT_LINK_OPEN, "a", i32(1));
  (&tok).attr_set(`href`, `https://example.com`);

  (val : Option(String)) = (&tok).attr_get(`href`);
  match(val,
    .Some(v) => assert((v == `https://example.com`), "should get correct value"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö attr_set overrides existing", {
  (tok : Token) = Token.new(.TT_LINK_OPEN, "a", i32(1));
  (&tok).attr_set(`href`, `old`);
  (&tok).attr_set(`href`, `new`);

  (val : Option(String)) = (&tok).attr_get(`href`);
  match(val,
    .Some(v) => assert((v == `new`), "should override with new value"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö attr_get returns None for missing attr", {
  (tok : Token) = Token.new(.TT_INLINE, "", i32(0));
  (val : Option(String)) = (&tok).attr_get(`class`);
  match(val,
    .Some(_) => assert(false, "should not find attr"),
    .None => ()
  );
};

test "Token ŌĆö attr_join creates new attr", {
  (tok : Token) = Token.new(.TT_PARAGRAPH_OPEN, "p", i32(1));
  (&tok).attr_join(`class`, `foo`);

  (val : Option(String)) = (&tok).attr_get(`class`);
  match(val,
    .Some(v) => assert((v == `foo`), "should create attr with value"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö attr_join appends to existing", {
  (tok : Token) = Token.new(.TT_PARAGRAPH_OPEN, "p", i32(1));
  (&tok).attr_join(`class`, `foo`);
  (&tok).attr_join(`class`, `bar`);

  (val : Option(String)) = (&tok).attr_get(`class`);
  match(val,
    .Some(v) => assert((v == `foo bar`), "should join with space"),
    .None => assert(false, "should find attr")
  );
};

test "Token ŌĆö multiple different attrs", {
  (tok : Token) = Token.new(.TT_LINK_OPEN, "a", i32(1));
  (&tok).attr_set(`href`, `https://example.com`);
  (&tok).attr_set(`title`, `Example`);
  (&tok).attr_join(`class`, `link`);

  assert(((&tok).attr_index(`href`) == i32(0)), "href at index 0");
  assert(((&tok).attr_index(`title`) == i32(1)), "title at index 1");
  assert(((&tok).attr_index(`class`) == i32(2)), "class at index 2");
  assert(((&tok).attr_index(`missing`) == i32(-1)), "missing returns -1");
};
