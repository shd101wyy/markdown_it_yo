// Legacy entity names that can be decoded without trailing semicolon.
_build_legacy_set :: (fn() -> HashSet(String))(
  {
    (s : HashSet(String)) = HashSet(String).new();
    s.add(`AElig`);
    s.add(`AMP`);
    s.add(`Aacute`);
    s.add(`Acirc`);
    s.add(`Agrave`);
    s.add(`Aring`);
    s.add(`Atilde`);
    s.add(`Auml`);
