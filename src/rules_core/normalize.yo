// Ported from: lib/rules_core/normalize.mjs (markdown-it v14.1.1)
//
// Normalize input string: unify line endings, replace NULL chars.

open import "std/string";
{ ArrayList } :: import "std/collections/array_list";
{ Token } :: import "../token.yo";
{ from_code_point } :: import "../common/char_utils.yo";
{ StateCore } :: import "./state_core.yo";

normalize :: (fn(state: *(StateCore)) -> unit)({
  (cr : String) = from_code_point(i32(0x0D));
  (lf : String) = from_code_point(i32(0x0A));
  (crlf : String) = `${cr}${lf}`;
  (null_char : String) = from_code_point(i32(0x00));
  (replacement : String) = from_code_point(i32(0xFFFD));

  // Normalize newlines: \r\n → \n, then remaining \r → \n
  state.*.src = state.*.src.replace_all(crlf, lf);
  state.*.src = state.*.src.replace_all(cr, lf);

  // Replace NULL characters with U+FFFD
  state.*.src = state.*.src.replace_all(null_char, replacement);
});

export normalize;
